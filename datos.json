<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PARTY PLAY - DJ KEVIN DAVID</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #e50914; --cyber: #00f2ff; --bg: #050505; --card-bg: #121212; }
        html { scroll-behavior: smooth; }
        body { background: var(--bg); color: #fff; font-family: 'Poppins', sans-serif; margin: 0; padding: 0; overflow-x: hidden; }

        /* PRELOADER TECNOLÓGICO (5 SEGUNDOS) */
        #loader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; display: flex; justify-content: center; align-items: center;
            z-index: 10000; overflow: hidden;
        }
        .cyber-bg {
            position: absolute; width: 100%; height: 100%;
            background-image: linear-gradient(rgba(0, 242, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 242, 255, 0.03) 1px, transparent 1px);
            background-size: 30px 30px; animation: bgMove 20s linear infinite;
        }
        @keyframes bgMove { from { background-position: 0 0; } to { background-position: 30px 30px; } }
        .loader-content { position: relative; z-index: 2; width: 320px; text-align: center; }
        .logo-box { position: relative; display: inline-block; margin-bottom: 25px; }
        .loader-logo { max-height: 90px; filter: drop-shadow(0 0 10px var(--cyber)); }
        .scan-line { position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: var(--cyber); box-shadow: 0 0 10px var(--cyber); animation: scan 2s infinite ease-in-out; }
        @keyframes scan { 0%, 100% { top: 0%; } 50% { top: 100%; } }
        .loader-text h1 { font-family: 'Orbitron'; font-size: 1rem; color: var(--cyber); margin: 10px 0; letter-spacing: 2px; }
        .signature { font-size: 0.85rem; font-weight: bold; text-transform: uppercase; }
        .signature span { color: var(--primary); }
        .progress-box { width: 100%; height: 4px; background: rgba(255,255,255,0.1); border-radius: 10px; margin: 20px 0; overflow: hidden; border: 1px solid rgba(0,242,255,0.2); }
        .progress-bar { width: 0%; height: 100%; background: var(--cyber); box-shadow: 0 0 15px var(--cyber); }
        .loader-hidden { opacity: 0 !important; visibility: hidden !important; transition: 1s ease-in-out; }

        /* HEADER */
        header { height: 70px; background: rgba(0,0,0,0.9); position: fixed; width: 100%; top: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .site-logo { max-height: 50px; cursor: pointer; }

        /* NAV Y BUSCADOR */
        .nav-container { margin-top: 90px; display: flex; flex-direction: column; align-items: center; gap: 15px; }
        .category-nav { display: flex; justify-content: center; flex-wrap: wrap; gap: 8px; width: 95%; }
        .category-nav a { background: #111; color: #fff; padding: 8px 16px; border-radius: 20px; text-decoration: none; font-size: 0.75rem; font-weight: bold; border: 1px solid #333; text-transform: uppercase; transition: 0.3s; }
        .category-nav a:hover { border-color: var(--primary); color: var(--primary); }
        .search-bar { width: 85%; max-width: 500px; padding: 12px 25px; border-radius: 30px; border: 1px solid #333; background: #000; color: white; outline: none; }

        /* SLIDER PRINCIPAL (TOP) */
        .main-slider { width: 95%; max-width: 1200px; height: 450px; margin: 25px auto; overflow: hidden; border-radius: 20px; position: relative; }
        .slider-track { display: flex; width: 100%; height: 100%; transition: transform 0.8s ease-in-out; }
        .slide { min-width: 100%; height: 100%; flex-shrink: 0; }
        .slide img { width: 100%; height: 100%; object-fit: cover; }

        /* FILAS DE PELÍCULAS TIPO STREAMING */
        .container { padding: 0 2% 100px 2%; }
        .category-section { margin-bottom: 50px; }
        h2 { font-family: 'Orbitron'; font-size: 1.2rem; margin-left: 3%; border-left: 5px solid var(--primary); padding-left: 15px; margin-bottom: 15px; text-transform: uppercase; }

        .carousel-wrapper { 
            position: relative; 
            width: 100%; 
            overflow-x: auto; 
            overflow-y: hidden;
            display: flex;
            scrollbar-width: none;
            -ms-overflow-style: none;
            cursor: grab;
        }
        .carousel-wrapper::-webkit-scrollbar { display: none; }

        .movie-grid { display: flex; gap: 20px; padding: 10px 3%; }

        .card { 
            width: 220px; /* Portadas más grandes */
            background: var(--card-bg); 
            border-radius: 12px; 
            flex-shrink: 0; 
            transition: transform 0.3s ease, border-color 0.3s; 
            cursor: pointer; 
            border: 1px solid #222; 
            overflow: hidden;
        }
        .card:hover { transform: scale(1.08); border-color: var(--cyber); z-index: 10; box-shadow: 0 10px 25px rgba(0,0,0,0.7); }
        .card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; pointer-events: none; }
        .card span { display: block; padding: 12px; font-size: 0.85rem; text-align: center; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* REPRODUCTOR */
        .player-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 10000; }
        .player-header { position: absolute; top: 0; width: 100%; padding: 15px; background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent); display: flex; justify-content: space-between; align-items: center; z-index: 11; }
        .close-btn { background: var(--primary); color: #fff; padding: 8px 18px; border-radius: 5px; cursor: pointer; font-family: 'Orbitron'; font-size: 10px; font-weight: bold; }
        iframe { width: 100%; height: 100%; border: none; }

        @media (max-width: 600px) { 
            .main-slider { height: 250px; }
            .card { width: 160px; }
            h2 { font-size: 1rem; }
        }
    </style>
</head>
<body>

<div id="loader">
    <div class="cyber-bg"></div>
    <div class="loader-content">
        <div class="logo-box"><img src="https://i.postimg.cc/X7bmMQHY/logo.png" class="loader-logo"><div class="scan-line"></div></div>
        <div class="loader-text">
            <h1>SISTEMA INICIADO</h1>
            <p class="signature">OPERADOR: <span>KEVIN DAVID</span></p>
        </div>
        <div class="progress-box"><div class="progress-bar" id="pBar"></div></div>
    </div>
</div>

<header><img src="https://i.postimg.cc/X7bmMQHY/logo.png" class="site-logo" onclick="window.scrollTo(0,0)"></header>

<div class="nav-container">
    <div class="category-nav">
        <a href="#accion-sec">Acción</a>
        <a href="#terror-sec">Terror</a>
        <a href="#biopic-sec">Biopic</a>
        <a href="#drama-sec">Drama</a>
        <a href="#comedia-sec">Comedia</a>
        <a href="#series-sec">Series</a>
        <a href="#party-sec" style="color:var(--cyber); border-color:var(--cyber);">Party Play</a>
    </div>
    <input type="text" id="searchInput" class="search-bar" placeholder="Buscar título o categoría..." onkeyup="filterCards()">
</div>

<div class="main-slider"><div class="slider-track" id="sliderTrack"></div></div>

<div class="container" id="content-container"></div>

<div id="videoPlayer" class="player-modal">
    <div class="player-header">
        <div id="playerTitle" style="font-family:'Orbitron'; font-size:12px; color:white;">CARGANDO NÚCLEO...</div>
        <div class="close-btn" onclick="closePlayer()">CERRAR [X]</div>
    </div>
    <iframe id="videoIframe" allowfullscreen></iframe>
</div>

<script>
    const categorias = ["accion", "terror", "biopic", "drama", "comedia", "series", "party-play"];
    let isUserInteracting = false;
    let interactionTimer;

    async function loadContent() {
        try {
            const res = await fetch('datos.json');
            const data = await res.json();
            const track = document.getElementById('sliderTrack');
            const container = document.getElementById('content-container');
            
            categorias.forEach(cat => {
                const section = document.createElement('div');
                section.className = 'category-section';
                section.id = `${cat}-sec`;
                section.style.display = 'none';
                section.innerHTML = `
                    <h2>${cat.replace('-', ' ')}</h2>
                    <div class="carousel-wrapper" id="scroll-${cat}">
                        <div class="movie-grid" id="${cat}-grid"></div>
                    </div>`;
                container.appendChild(section);
            });

            data.forEach(item => {
                const tipos = item.tipos || [item.tipo];
                if(tipos.includes('slider')) track.innerHTML += `<div class="slide"><img src="${item.img}"></div>`;
                tipos.forEach(t => {
                    const grid = document.getElementById(`${t}-grid`);
                    const section = document.getElementById(`${t}-sec`);
                    if(grid && section) {
                        section.style.display = 'block';
                        grid.innerHTML += `
                            <div class="card" data-title="${item.titulo}" onclick="openPlayer('${item.url}', '${item.titulo}')">
                                <img src="${item.img}">
                                <span>${item.titulo}</span>
                            </div>`;
                    }
                });
            });

            initAutoScroll();
            startSlider();
            runLoader();
        } catch (e) { document.getElementById('loader').style.display='none'; }
    }

    function runLoader() {
        let p = 0;
        const bar = document.getElementById('pBar');
        const int = setInterval(() => {
            p++; bar.style.width = p + "%";
            if(p >= 100) { clearInterval(int); setTimeout(() => document.getElementById('loader').classList.add('loader-hidden'), 600); }
        }, 45);
    }

    function initAutoScroll() {
        const wrappers = document.querySelectorAll('.carousel-wrapper');
        wrappers.forEach(wrapper => {
            let scrollSpeed = 1.8; // VELOCIDAD DEL MOVIMIENTO

            const move = () => {
                if (!isUserInteracting) {
                    wrapper.scrollLeft += scrollSpeed;
                    if (wrapper.scrollLeft >= (wrapper.scrollWidth - wrapper.clientWidth - 1)) {
                        wrapper.scrollLeft = 0;
                    }
                }
                requestAnimationFrame(move);
            };

            const stopInteraction = () => {
                isUserInteracting = true;
                clearTimeout(interactionTimer);
                interactionTimer = setTimeout(() => { isUserInteracting = false; }, 2000);
            };

            wrapper.addEventListener('mousedown', () => isUserInteracting = true);
            wrapper.addEventListener('mouseup', stopInteraction);
            wrapper.addEventListener('touchstart', () => isUserInteracting = true, {passive: true});
            wrapper.addEventListener('touchend', stopInteraction, {passive: true});
            wrapper.addEventListener('mouseenter', () => isUserInteracting = true);
            wrapper.addEventListener('mouseleave', stopInteraction);

            move();
        });
    }

    function startSlider() {
        const track = document.getElementById('sliderTrack');
        let index = 0;
        const slides = document.getElementsByClassName('slide');
        if(slides.length > 1) {
            setInterval(() => {
                index = (index + 1) % slides.length;
                track.style.transform = `translateX(-${index * 100}%)`;
            }, 5000);
        }
    }

    function openPlayer(url, title) {
        document.getElementById('videoIframe').src = url;
        document.getElementById('playerTitle').innerText = title.toUpperCase();
        document.getElementById('videoPlayer').style.display = 'block';
        document.body.style.overflow = 'hidden';
    }

    function closePlayer() {
        document.getElementById('videoPlayer').style.display = 'none';
        document.getElementById('videoIframe').src = '';
        document.body.style.overflow = 'auto';
    }

    function filterCards() {
        let input = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('.card').forEach(card => {
            card.style.display = card.getAttribute('data-title').toLowerCase().includes(input) ? "block" : "none";
        });
    }
    window.onload = loadContent;
</script>
</body>
</html>
